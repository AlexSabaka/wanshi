{
  "name": "kg-gen",
  "version": "1.0.0",
  "description": "Knowledge Graph Generator",
  "main": "./src/index.ts",
  "bin": {
    "kg-gen": "./dist/index.js"
  },
  "scripts": {
    "start": "ts-node ./src/index.ts",
    "dev": "nodemon --watch . --exec ts-node -- ./src/index.ts",
    "build": "tsc",
    "test": "./node_modules/.bin/jest"
  },
  "author": "Alex Sabaka",
  "license": "GPL-2.0-only",
  "nodemonConfig": {
    "ext": "*.ts,*.js,*.json",
    "ignore": [
      "**/test/**",
      "**/docs/**"
    ]
  },
  "dependencies": {
    "@langchain/core": "^0.3.57",
    "@langchain/textsplitters": "^0.1.0",
    "@types/node": "^22.7.4",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "dree": "^5.1.5",
    "glob": "^11.0.2",
    "highlight.js": "^11.10.0",
    "ollama": "^0.5.16",
    "pdf-parser": "^1.0.5",
    "pdf-text-reader": "^5.1.0",
    "pdfreader": "^3.0.7",
    "pretty-format": "^29.7.0",
    "readline-sync": "^1.4.10",
    "typescript": "^5.6.2",
    "zod": "^3.25.48",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/readline-sync": "^1.4.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.2.5"
  }
}
